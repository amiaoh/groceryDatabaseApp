{
  "name": "@grocery/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "vercel-build": "esbuild src/vercel-entry.ts --bundle --platform=node --target=node22 --format=esm --external:puppeteer-core --external:fsevents --outfile=api/index.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push --force",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=.env src/db/seed.ts"
  },
  "dependencies": {
    "@grocery/shared": "workspace:*",
    "@hono/node-server": "^1.12.0",
    "@hono/zod-validator": "^0.7.6",
    "@neondatabase/serverless": "^0.10.0",
    "better-auth": "^1.2.0",
    "drizzle-orm": "^0.41.0",
    "drizzle-zod": "^0.7.0",
    "hono": "^4.7.0",
    "puppeteer-core": "^24.41.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.4",
    "esbuild": "^0.25.0",
    "pg": "^8.20.0",
    "postgres": "^3.4.9",
    "tsx": "^4.19.0",
    "typescript": "^5"
  }
}
